{
  "name": "heartbeat",
  "version": "0.1.5",
  "type": "module",
  "private": true,
  "bin": {
    "heartbeat": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts start",
    "dev": "bun run src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:cli": "bun build --compile src/cli/index.ts --outfile dist/heartbeat",
    "build:cli:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli/index.ts --outfile dist/heartbeat-darwin-arm64",
    "build:cli:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/cli/index.ts --outfile dist/heartbeat-darwin-x64",
    "build:cli:linux-x64": "bun build --compile --target=bun-linux-x64 src/cli/index.ts --outfile dist/heartbeat-linux-x64",
    "build:release": "bash scripts/build-release.sh"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "croner": "^9.0.0",
    "hono": "^4.6.14",
    "js-yaml": "^4.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.9.2"
  }
}
